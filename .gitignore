# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
teacher-dashboard/node_modules
student-dashboard/node_modules
teacher-dashboard/.pnp
student-dashboard/.pnp
teacher-dashboard/.pnp.*
student-dashboard/.pnp.*

# testing
teacher-dashboard/coverage
student-dashboard/coverage

# next.js
teacher-dashboard/.next/
teacher-dashboard/out/
student-dashboard/.next/
student-dashboard/out/

# production
teacher-dashboard/build
student-dashboard/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
teacher-dashboard/*.tsbuildinfo
teacher-dashboard/next-env.d.ts
student-dashboard/*.tsbuildinfo
student-dashboard/next-env.d.ts

# python backend
app/backend/__pycache__/
app/backend/**/__pycache__/
app/backend/.env
app/backend/**/*.pyc
app/backend/**/*.pyo
app/backend/**/*.pyd
app/backend/.pytest_cache/
app/backend/**/.pytest_cache/
app/backend/*.db
app/backend/*.db-journal
app/backend/venv/
app/backend/env/
app/backend/ENV/
app/backend/_legacy_*/
*.log
.vscode/
.idea/
*.swp
*.swo
*~

# service account keys (NEVER commit)
*-service-account.json
*-service-account-key.json

# dev notes & reference (local only)
dev/*
!dev/research/
dev/research/*
!dev/research/.gitkeep
!dev/slides/
!dev/chat-summary.md
screenshots/
